# Google Maps (optional). When set, a static map tile is shown for your parked location.
# Get a key at https://console.cloud.google.com/apis/credentials (enable "Maps Static API").
VITE_GOOGLE_MAPS_API_KEY=

# Gemini (optional). When set, photos of parking signs are sent to Gemini to extract parking rules.
# Get a key at https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# Supabase (optional). When set, users can sign in and sync parking status across devices.
# Create a project at https://supabase.com, then run supabase-schema.sql in the SQL Editor.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
